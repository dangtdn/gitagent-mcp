{
  "name": "@dangtdn/gitagent-mcp-server",
  "version": "1.0.2",
  "type": "module",
  "description": "MCP Server for GitAgent Manager - Connect your GitHub repositories to AI editors like Cursor, VS Code, Antigravity, and more",
  "main": "dist/index.js",
  "bin": {
    "gitagent-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start:http": "node dist/http-server.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github",
    "ai",
    "cursor",
    "vscode",
    "antigravity",
    "claude",
    "gitagent",
    "git",
    "issues",
    "pull-requests"
  ],
  "author": "dangtdn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangtdn/gitagent-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/dangtdn/gitagent-mcp/issues"
  },
  "homepage": "https://github.com/dangtdn/gitagent-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "tsx": "^4.7.0",
    "typescript": "~5.8.2"
  }
}
